{
  "$schema": "./node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "PhotoAnalyzer",
  "version": "0.1.0",
  "identifier": "com.photoanalyzer.app",
  "build": {
    "beforeDevCommand": "npm --prefix ../web/frontend run dev",
    "beforeBuildCommand": "npm --prefix ../web/frontend run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../web/frontend/dist"
  },
  "app": {
    "windows": [
      {
        "title": "PhotoAnalyzer",
        "width": 1280,
        "height": 860,
        "resizable": true,
        "fullscreen": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.ico",
      "icons/icon.icns",
      "icons/icon.png"
    ]
  }
}