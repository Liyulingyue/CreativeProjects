# ============================================================================
# TravelSites 环境变量配置
# 复制此文件为 .env 并填入真实值（.env 不会进 git）
# 启动时部分配置会写入 SQLite（http://localhost:8000/data/travelsites.db）
# ============================================================================

# ----------------------------------------------------------------------------
# LLM 配置（必填）
# ----------------------------------------------------------------------------
# OpenAI 兼容协议的 API key（也支持 DeepSeek/百度千帆/MiniMax 等）
OPENAI_API_KEY="your-api-key-here"

# API base URL
# OpenAI 官方:   https://api.openai.com/v1
# DeepSeek:     https://api.deepseek.com/v1
# MiniMax:      https://api.minimaxi.com/v1
# 百度千帆:     https://qianfan.baidubce.com/v2
OPENAI_BASE_URL="https://api.minimaxi.com/v1"

# 使用的模型名（任何支持 function calling 的模型都可以）
OPENAI_VISION_MODEL_NAME="MiniMax-M3"

# ----------------------------------------------------------------------------
# 定时刷新任务（可选）
# ----------------------------------------------------------------------------
# 是否启用后台定时刷新（关闭则需手动 POST /api/refresh 触发）
# 生产建议设为 true，自动每天凌晨更新 matrix
REFRESH_ENABLED=false

# 刷新间隔（秒）
# - 测试: 3600 (1 小时)
# - 生产: 86400 (24 小时，建议凌晨低峰)
REFRESH_INTERVAL_SECONDS=3600

# ----------------------------------------------------------------------------
# Matrix 生成配置（控制每个城市预生成多少 cell）
# ----------------------------------------------------------------------------
# 未来出发日偏移天数（从今天起 +N 天内的出发日都预生成）
# 例子: 今天 6/29，OFFSET=7 → 预生成 6/29 ~ 7/5 出发
# 例子: OFFSET=14 → 预生成 6/29 ~ 7/12 出发
# 推荐:
#   - 测试: 1 (1×2=2 cells/city, 35 城市=70 次 LLM)
#   - 上线初期: 3 (3×2=6 cells/city, 35 城市=210 次)
#   - 稳定生产: 7 (7×5=35 cells/city, 35 城市=1225 次)
MATRIX_MAX_OFFSET=1

# 出行天数（1~N 天都要预生成）
# 例子: DURATION=2 → 预生成 1 天和 2 天的行程
# 推荐:
#   - 测试: 2 (少而精)
#   - 上线: 5 (覆盖周末/小长假/长假)
MATRIX_MAX_DURATION=2

# 并发 LLM 调用数（同时发多少请求给 API）
# 注意：太高会触发 API rate limit
# 推荐: 3-10（具体看 API 限额）
MATRIX_CONCURRENCY=3

# ----------------------------------------------------------------------------
# 种子城市列表
# ----------------------------------------------------------------------------
# 初始预生成行程的城市（逗号分隔，不要加空格）
# 启动时：
#   1. DB 为空 → 用这个列表初始化
#   2. DB 非空 + 与此一致 → 不动
#   3. DB 非空 + 与此不一致 → 保留 DB（admin 在后台的修改优先）
#   4. SEED_CITIES_SYNC=true → 强制 .env 覆盖 DB
# 也可以通过 admin API (PUT /api/admin/cities) 动态增删
SEED_CITIES=济南,大同,青岛,烟台,威海,杭州,苏州,南京,宁波,绍兴,厦门,福州,泉州,霞浦,西安,成都,重庆,昆明,大理,丽江,桂林,北海,涠洲岛,三亚,海口,万宁,黄山,宏村,婺源,千岛湖,敦煌,张掖,嘉峪关,拉萨,林芝

# 启动时是否强制用 SEED_CITIES 覆盖 DB
# - true:  启动时 .env 永远赢（admin 修改的会被冲掉）
# - false: DB 优先（默认，推荐生产用）
SEED_CITIES_SYNC=false

# ----------------------------------------------------------------------------
# 管理员账户（启动时自动创建）
# ----------------------------------------------------------------------------
# 仅在无 admin 用户时生效；已有 admin 时这些值被忽略
# 生产前必须改 ADMIN_PASSWORD（不能是 admin123）
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
ADMIN_EMAIL=admin@travelsites.local
ADMIN_DISPLAY_NAME=系统管理员

# ----------------------------------------------------------------------------
# 认证
# ----------------------------------------------------------------------------
# Session 有效期（天），过期需重新登录
# 推荐: 30（生产可缩短到 7）
SESSION_DAYS=30

# ----------------------------------------------------------------------------
# POI 接入（高德地图，可选）
# ----------------------------------------------------------------------------
# 是否启用高德 POI API 补充景点数据
# - false: 只用内置 attractions 表（35 城市 134 景点）
# - true:  启动后 admin 可调用 POST /api/admin/poi/import 补充
POI_SOURCE_ENABLED=false

# 高德开放平台 Web 服务 API Key（https://lbs.amap.com/ 申请）
# 免费版每天 5000 次调用，足够补充上千个景点
AMAP_API_KEY=

# 启动时是否用 .env 覆盖 DB 里 admin 的密码/邮箱
# - true:  修改 .env 重启即生效（生产部署推荐）
# - false: DB 已有 admin 时不覆盖（默认）
ADMIN_SYNC=false
