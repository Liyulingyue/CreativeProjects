# Frontend environment variables (Vite reads .env at build time)
# All variables must be prefixed with VITE_

# Backend API base URL
# - In dev: leave empty, Vite proxy (/api → http://127.0.0.1:8000) is used
# - In prod: set to your backend URL, e.g. https://api.example.com
VITE_API_BASE_URL=

# Enable LLM-powered features (narration, chat, photo eval)
# - true:  use OpenAI-compatible backend for personalized output
# - false: use rule-based fallback only (no LLM, fully offline-capable)
VITE_USE_LLM=true

# Demo mode (hides login UI, shows demo data)
# - true:  /me/* endpoints return mock data
# - false: real backend
VITE_DEMO_MODE=false

# PWA install prompt
# - auto:  show "add to home screen" hint after 2 visits
# - manual: only show if user taps
# - off:   never show
VITE_INSTALL_PROMPT=auto

# Debug: log API requests to console
VITE_DEBUG_API=false
